<ui:FluentWindow x:Class="VirtuExAdmin.Windows.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="VirtuEx - Sign In"
        Height="400"
        Width="400"
        ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
        ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        ResizeMode="NoResize"
        WindowBackdropType="Mica">
    <StackPanel>
        <!-- TitleBar -->
        <ui:TitleBar Title="VirtuEx"
                     CanMaximize="False"
                     ShowClose="True"
                     ShowMaximize="False"
                     ShowMinimize="False"/>

        <!-- Content -->
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title -->
                <RowDefinition Height="*"/>     <!-- Spacer -->
                <RowDefinition Height="Auto"/>  <!-- Form -->
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock x:Name="Title"
                       Grid.Row="0"
                       Text="Sign In"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <!-- Login Panel -->
            <StackPanel x:Name="LoginPanel"
                        Grid.Row="2"
                        Visibility="Visible">

                <TextBlock Text="Username"/>
                <ui:TextBox x:Name="EmailBox"
                            Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,0,15"/>

                <TextBlock Text="Password"/>
                <ui:PasswordBox x:Name="PasswordBox"
                                Password="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,5,0,20"/>
                
                <CheckBox Margin="0,5,0,20" Content="Remember Me" />

                <ui:Button Appearance="Primary"
                           Content="Sign In"
                           Icon="{ui:SymbolIcon LockClosed24}"
                           Command="{Binding LoginCommand}"
                           IsEnabled="True"/>
            </StackPanel>

            <!-- 2FA Panel -->
            <StackPanel x:Name="TwoFactorPanel"
                        Grid.Row="2"
                        Visibility="Collapsed">

                <TextBlock Text="Enter verification code"/>
                <ui:TextBox x:Name="TwoFactorBox"
                            PlaceholderText="Enter 6-digit code"
                            MaxLength="6"
                            HorizontalContentAlignment="Center"
                            FontSize="18"
                            Height="40"
                            Margin="0,0,0,20"/>

                <ui:Button Appearance="Primary"
                           Content="Verify"
                           Height="40"
                           Icon="{ui:SymbolIcon ShieldCheckmark24}"
                           IsEnabled="True"/>
            </StackPanel>

        </Grid>
    </StackPanel>
</ui:FluentWindow>