<Window x:Class="VirtuExAdmin.Windows.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Sign In"
        Height="400"
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="*"/>     <!-- Spacer -->
            <RowDefinition Height="Auto"/>  <!-- Form -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock x:Name="Title"
                   Grid.Row="0"
                   Text="Sign In"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- Login Panel -->
        <StackPanel x:Name="LoginPanel"
                    Grid.Row="2"
                    Visibility="Visible">

            <TextBlock Text="Username"/>
            <TextBox x:Name="UsernameBox"
                     Margin="0,5,0,15"/>

            <TextBlock Text="Password"/>
            <PasswordBox x:Name="PasswordBox"
                         Margin="0,5,0,20"/>

            <ui:Button Appearance="Primary"
                        Content="Login"
                        Cursor="Hand"
                        Click="Login_Click"
                        Icon="{ui:SymbolIcon Fingerprint48}"/>
        </StackPanel>

        <!-- 2FA Panel -->
        <StackPanel x:Name="TwoFactorPanel"
                    Grid.Row="2"
                    Visibility="Collapsed">

            <TextBlock Text="Enter verification code"/>
            <TextBox x:Name="TwoFactorBox"
                     Height="30"
                     Margin="0,5,0,20"
                     MaxLength="6"
                     HorizontalContentAlignment="Center"/>

            <Button Content="Verify"
                    Cursor="Hand"/>
        </StackPanel>

    </Grid>
</Window>