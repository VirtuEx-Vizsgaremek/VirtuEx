<Page x:Class="VirtuExAdmin.Pages.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:VirtuExAdmin.Pages"
      xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:serializables="clr-namespace:VirtuExAdmin.Serializables"
      mc:Ignorable="d"
      Title="WebPage"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      d:DesignHeight="600"
      d:DesignWidth="1000">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: Users list + toolbar -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Users" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />

                <ui:Button Grid.Column="1" Content="Add new user" Appearance="Secondary" Click="AddNewUser_Click" />
            </Grid>

            <ui:ListView
                Grid.Row="2"
                ItemsSource="{Binding Users}"
                SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                SelectionMode="Single"
                BorderThickness="0"
                Background="Transparent">

                <ui:ListView.ItemContainerStyle>
                    <Style TargetType="ui:ListViewItem" BasedOn="{StaticResource {x:Type ui:ListViewItem}}">
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ui:ListView.ItemContainerStyle>

                <ui:ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type serializables:User}">
                        <Border Padding="16" 
                                Background="{DynamicResource ControlFillColorDefaultBrush}" 
                                CornerRadius="8" 
                                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" 
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock 
                                    Grid.Row="0" Grid.Column="0"
                                    Text="{Binding FullName}" 
                                    FontSize="16" 
                                    FontWeight="SemiBold" 
                                    Margin="0,0,0,2"/>

                                <TextBlock 
                                    Grid.Row="1" Grid.Column="0"
                                    Text="{Binding Username}" 
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                    FontSize="13"/>

                                <!-- Registration date shown on the right column -->
                                <TextBlock
                                    Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                    Text="{Binding RegistrationDate}"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    FontSize="12"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right"/>

                                <StackPanel 
                                    Grid.Row="3" Grid.Column="0" 
                                    Orientation="Horizontal" 
                                    VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#9E9E9E" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Activated}" Value="True">
                                                        <Setter Property="Fill" Value="#4CAF50" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <TextBlock FontSize="13">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Inactive" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Activated}" Value="True">
                                                        <Setter Property="Text" Value="Active" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ui:ListView.ItemTemplate>
            </ui:ListView>
        </Grid>

        <!-- RIGHT: Details -->
        <Border
            Grid.Column="2"
            Background="Transparent"
            CornerRadius="8"
            BorderBrush="Transparent"
            BorderThickness="0"
            Padding="16">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header: user + subscription quick actions -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0" Width="64" Height="64" Fill="{DynamicResource ControlFillColorSecondaryBrush}" Margin="0,0,16,0" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedUser.FullName}" FontSize="24" FontWeight="Bold" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding SelectedUser.Username}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="14" />
                        <TextBlock Text="{Binding SelectedUser.RegistrationDate}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding SubscriptionUserType}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding SubscriptionPlanName}" Foreground="#4CAF50" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding SubscriptionCredits, StringFormat=Credits: {0}/mo}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" HorizontalAlignment="Right"/>

                        <WrapPanel HorizontalAlignment="Right" Margin="0,10,0,0">
                            <ui:Button Content="Edit subscription" Appearance="Secondary" Margin="0,0,8,8" Click="EditSubscription_Click" />
                            <ui:Button Content="Wallet" Appearance="Secondary" Margin="0,0,0,8" Click="OpenWallet_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <Rectangle Grid.Row="1" Height="1" Fill="{DynamicResource SurfaceStrokeColorDefaultBrush}" Margin="0,6,0,10" />

                <!-- Content (keep ScrollViewer if needed but should not scroll at normal size) -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,16,0">

                        <!-- Personal information header (title only) -->
                        <TextBlock Text="Personal information" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <!-- Create-only: Username -->
                        <TextBlock Text="USERNAME" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"
                                   Visibility="{Binding IsCreateMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <ui:TextBox Text="{Binding EditableUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"
                                    Visibility="{Binding IsCreateMode, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <TextBlock Text="FULL NAME" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding EditableFullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                        <TextBlock Text="EMAIL" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding EditableEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                        <!-- Create-only: Password -->
                        <TextBlock Text="PASSWORD" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"
                                   Visibility="{Binding IsCreateMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <ui:TextBox Text="{Binding EditablePassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"
                                    Visibility="{Binding IsCreateMode, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <TextBlock Text="REGISTRATION DATE" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding EditableRegistrationDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="False" Margin="0,0,0,12" />

                        <!-- Admin settings header row with inline action -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Admin settings" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ui:Button Grid.Column="1" Content="Apply permissions" Appearance="Secondary" Click="ApplyPermissions_Click" Margin="12,0,0,0" />
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="PERMISSIONS" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>

                                <ComboBox SelectedValue="{Binding EditablePermissions, Mode=TwoWay}" SelectedValuePath="Tag" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="User" Tag="0" />
                                    <ComboBoxItem Content="Admin" Tag="1" />
                                </ComboBox>

                                <CheckBox Content="Activated" Margin="0,10,0,0" IsChecked="{Binding EditableActivated, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="STATE" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                <ComboBox SelectedValue="{Binding EditableStatus, Mode=TwoWay}" SelectedValuePath="Content" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Active" />
                                    <ComboBoxItem Content="Pending" />
                                    <ComboBoxItem Content="Inactive" />
                                    <ComboBoxItem Content="Banned" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Security" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="4" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Set security settings as administrator" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,16,0" />

                                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <ui:Button Content="Reset password" Appearance="Secondary" Margin="0,0,8,8" />
                                    <ui:Button Content="Delete 2FA" Appearance="Danger" Margin="0,0,0,8" />
                                </WrapPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Fixed bottom action bar -->
                <Border Grid.Row="3"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                        BorderThickness="1,0,0,0"
                        Padding="12,10"
                        CornerRadius="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0" Content="Delete profile" Appearance="Danger" />

                        <WrapPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <ui:Button Content="Cancel" Appearance="Secondary" Margin="0,0,8,0" Click="Cancel_Click" />

                            <ui:Button Appearance="Primary" Click="SaveChanges_Click">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Content" Value="Save changes" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCreateMode}" Value="True">
                                                <Setter Property="Content" Value="Create" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                        </WrapPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Page>