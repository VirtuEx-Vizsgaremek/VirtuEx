<Page x:Class="VirtuExAdmin.Pages.TransactionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:VirtuExAdmin.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      Title="TransactionsPage"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      d:DesignHeight="600"
      d:DesignWidth="1100">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Transaction History"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <!-- Filter bar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:TextBox Grid.Column="0"
                        PlaceholderText="Search by user, currency, status..."
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,8,0"/>

            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding StatusFilterOptions}"
                      SelectedItem="{Binding StatusFilter}"
                      MinWidth="120"
                      Margin="0,0,8,0"/>

            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding DirectionFilterOptions}"
                      SelectedItem="{Binding DirectionFilter}"
                      MinWidth="100"
                      Margin="0,0,8,0"/>

            <ComboBox Grid.Column="3"
                      ItemsSource="{Binding PageSizeOptions}"
                      SelectedItem="{Binding PageSize}"
                      MinWidth="80"
                      Margin="0,0,8,0"/>

            <ToggleButton Grid.Column="4"
                          Content="Group by User"
                          IsChecked="{Binding GroupByUser}"
                          Margin="0,0,8,0"/>

            <ui:Button Grid.Column="5"
                       Content="Refresh"
                       Command="{Binding RefreshCommand}"
                       Margin="0,0,8,0"/>

            <ui:Button Grid.Column="6"
                       Content="Clear"
                       Command="{Binding ClearFiltersCommand}"/>
        </Grid>

        <!-- DataGrid -->
        <ui:DataGrid Grid.Row="2"
                     ItemsSource="{Binding TransactionsView}"
                     IsReadOnly="True"
                     CanUserSortColumns="True"
                     AutoGenerateColumns="False">
            <ui:DataGrid.Resources>
                <Style x:Key="CellText" TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="4,0,16,0"/>
                </Style>
            </ui:DataGrid.Resources>

            <ui:DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,6">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                                <TextBlock Text="{Binding ItemCount, StringFormat=' — {0} transactions'}"
                                           Opacity="0.65"
                                           FontSize="13"/>
                            </StackPanel>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ui:DataGrid.GroupStyle>

            <ui:DataGrid.Columns>
                <DataGridTextColumn Header="User"
                                    Binding="{Binding User.Username}"
                                    SortMemberPath="User.Username"
                                    ElementStyle="{StaticResource CellText}"
                                    Width="Auto"/>
                <DataGridTextColumn Header="Full Name"
                                    Binding="{Binding User.FullName}"
                                    SortMemberPath="User.FullName"
                                    ElementStyle="{StaticResource CellText}"
                                    Width="Auto"/>
                <DataGridTextColumn Header="Symbol"
                                    Binding="{Binding CurrencySymbol}"
                                    SortMemberPath="CurrencySymbol"
                                    ElementStyle="{StaticResource CellText}"
                                    Width="Auto"/>
                <DataGridTextColumn Header="Currency"
                                    Binding="{Binding CurrencyName}"
                                    SortMemberPath="CurrencyName"
                                    ElementStyle="{StaticResource CellText}"
                                    Width="Auto"/>
                <DataGridTextColumn Header="Amount"
                                    Binding="{Binding Amount}"
                                    SortMemberPath="Amount"
                                    ElementStyle="{StaticResource CellText}"
                                    Width="Auto"/>
                <DataGridTextColumn Header="Direction"
                                    Binding="{Binding Direction}"
                                    SortMemberPath="Direction"
                                    ElementStyle="{StaticResource CellText}"
                                    Width="Auto"/>
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    SortMemberPath="Status"
                                    ElementStyle="{StaticResource CellText}"
                                    Width="Auto"/>
                <DataGridTextColumn Header="Date"
                                    Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                    SortMemberPath="CreatedAt"
                                    ElementStyle="{StaticResource CellText}"
                                    Width="Auto"/>
            </ui:DataGrid.Columns>
        </ui:DataGrid>

        <!-- Pagination controls -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding PaginationSummary}"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <ui:Button Content="«"
                           Command="{Binding FirstPageCommand}"
                           Margin="0,0,4,0"
                           MinWidth="32"/>
                <ui:Button Content="‹"
                           Command="{Binding PrevPageCommand}"
                           Margin="0,0,4,0"
                           MinWidth="32"/>
                <TextBlock VerticalAlignment="Center"
                           Margin="8,0"
                           Text="{Binding PageInfo}"/>
                <ui:Button Content="›"
                           Command="{Binding NextPageCommand}"
                           Margin="4,0,4,0"
                           MinWidth="32"/>
                <ui:Button Content="»"
                           Command="{Binding LastPageCommand}"
                           Margin="4,0,0,0"
                           MinWidth="32"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
