<Page x:Class="VirtuExAdmin.Pages.DetailedCurrencyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:VirtuExAdmin.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      Title="DetailedCurrencyPage"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      d:DesignHeight="700"
      d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Currency Details"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6" />

        <TextBlock Grid.Row="1"
                   Opacity="0.75"
                   Margin="0,0,0,16">
            <Run Text="{Binding Symbol}"/>
            <Run Text="—"/>
            <Run Text="{Binding Name}"/>
        </TextBlock>

        <Border Grid.Row="2"
                Padding="18"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                    <TextBlock Text="Symbol" Margin="0,0,0,6" />
                    <ui:TextBox Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,12">
                    <TextBlock Text="Name" Margin="0,0,0,6" />
                    <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,12">
                    <TextBlock Text="Precision" Margin="0,0,0,6" />
                    <ComboBox SelectedItem="{Binding Precision}"
                              ItemsSource="{Binding PrecisionOptions}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,12">
                    <TextBlock Text="Update Frequency" Margin="0,0,0,6" />
                    <ComboBox SelectedItem="{Binding UpdateFreqency}"
                              ItemsSource="{Binding UpdateFrequencyOptions}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Currency Type" Margin="0,0,0,6" />
                    <ComboBox SelectedItem="{Binding Type}"
                              ItemsSource="{Binding CurrencyTypeOptions}" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <ui:Button Content="Cancel"
                       Command="{Binding CancelCommand}"
                       Margin="0,0,8,0" />
            <ui:Button Content="Reset"
                       Command="{Binding ResetFieldsCommand}"
                       Margin="0,0,8,0" />
            <ui:Button Content="Save"
                       Command="{Binding SaveCommand}"
                       Appearance="Primary"
                       Background="{DynamicResource AccentFillColorDefaultBrush}"
                       Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                       Icon="{ui:SymbolIcon Save24}" />
        </StackPanel>
    </Grid>
</Page>
